{
  "title": "Node Metrics - IT Connect",
  "version": 1,
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "CPU Usage",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{ instance }}"
        }
      ],
      "yaxes": [
        { "format": "percent", "label": "CPU Usage", "min": 0, "max": 100 }
      ],
      "legend": { "show": true, "values": true, "min": false, "max": false, "current": true, "total": false, "avg": true }
    },
    {
      "title": "Memory Usage",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemFree_bytes - node_memory_Cached_bytes - node_memory_Buffers_bytes) / node_memory_MemTotal_bytes * 100",
          "legendFormat": "{{ instance }}"
        }
      ],
      "yaxes": [
        { "format": "percent", "label": "Memory Usage", "min": 0, "max": 100 }
      ],
      "legend": { "show": true, "values": true, "min": false, "max": false, "current": true, "total": false, "avg": true }
    },
    {
      "title": "Disk Usage",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "(node_filesystem_size_bytes{mountpoint=\"/\"} - node_filesystem_free_bytes{mountpoint=\"/\"}) / node_filesystem_size_bytes{mountpoint=\"/\"} * 100",
          "legendFormat": "{{ instance }}"
        }
      ],
      "yaxes": [
        { "format": "percent", "label": "Disk Usage", "min": 0, "max": 100 }
      ],
      "legend": { "show": true, "values": true, "min": false, "max": false, "current": true, "total": false, "avg": true }
    },
    {
      "title": "Network I/O",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total[5m])",
          "legendFormat": "RX - {{ device }}"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total[5m])",
          "legendFormat": "TX - {{ device }}"
        }
      ],
      "yaxes": [
        { "format": "bps", "label": "Throughput" }
      ],
      "legend": { "show": true, "values": true, "min": false, "max": false, "current": true, "total": false, "avg": true }
    },
    {
      "title": "System Load",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "1m - {{ instance }}"
        },
        {
          "expr": "node_load5",
          "legendFormat": "5m - {{ instance }}"
        },
        {
          "expr": "node_load15",
          "legendFormat": "15m - {{ instance }}"
        }
      ],
      "yaxes": [
        { "format": "short", "label": "Load" }
      ],
      "legend": { "show": true, "values": true, "min": false, "max": false, "current": true, "total": false, "avg": true }
    },
    {
      "title": "Disk I/O",
      "type": "graph",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total[5m])",
          "legendFormat": "Read - {{ device }}"
        },
        {
          "expr": "rate(node_disk_written_bytes_total[5m])",
          "legendFormat": "Write - {{ device }}"
        }
      ],
      "yaxes": [
        { "format": "Bps", "label": "Throughput" }
      ],
      "legend": { "show": true, "values": true, "min": false, "max": false, "current": true, "total": false, "avg": true }
    }
  ],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "query": "label_values(node_boot_time_seconds, instance)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      }
    ]
  },
  "tags": ["it-connect", "node", "infrastructure"],
  "schemaVersion": 27,
  "style": "dark",
  "timezone": "utc"
}
